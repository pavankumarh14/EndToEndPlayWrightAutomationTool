# Optional semantic review provider: none, ollama, or gemini.
AI_PROVIDER=gemini

# Gemini is called only by the API server. Never add the real key to Git.
GEMINI_API_KEY=replace-with-your-key
GEMINI_MODEL=gemini-2.5-flash

# Alternative local provider.
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
